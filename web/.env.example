NEXT_PUBLIC_SAK_WEBAUTHN_VERIFIER=CCMR63YE5T7MPWREF3PC5XNTTGXFSB4GYUGUIT5POHP2UGCS65TBIUUU

# Native XLM Stellar Asset Contract
NEXT_PUBLIC_NATIVE_TOKEN=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Planet contract address. Run `bash scripts/deploy-testnet.sh` to deploy your
# own and have this populated automatically in web/.env.local.
NEXT_PUBLIC_PLANET_CONTRACT=
