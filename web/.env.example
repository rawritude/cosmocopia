NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Smart Account Kit (kalepail/smart-account-kit) testnet deployment.
# These are the canonical addresses published in the kit's demo .env.example.
